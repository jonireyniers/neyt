{
	"version": 3,
	"routes": [
		{
			"src": "^/site$",
			"headers": {
				"Location": "/"
			},
			"status": 301
		},
		{
			"src": "^/site(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?$",
			"headers": {
				"Location": "/"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/manage/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/company/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/company/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/furniture/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/company/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/furniture/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/?$",
			"dest": "_render"
		},
		{
			"src": "^/furniture/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/furniture/?$",
			"dest": "_render"
		},
		{
			"src": "^/nl/company/?$",
			"dest": "_render"
		},
		{
			"src": "^/nl/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/nl/furniture/?$",
			"dest": "_render"
		},
		{
			"src": "^/nl/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^/nl/?$",
			"dest": "_render"
		},
		{
			"src": "^/site/?$",
			"dest": "_render"
		},
		{
			"src": "^/site(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/?$",
			"dest": "_render"
		}
	]
}