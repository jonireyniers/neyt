---
// filepath: src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getFurniture } from '../lib/supabase';
import companyData from '../data/company.json';

const locale: 'en' | 'fr' | 'nl' = 'en';
const allFurniture = await getFurniture();
const recentFurniture = allFurniture.slice(0, 6); // Laatste 6 items

const categoryLabels = {
  'adult-bedrooms': { en: 'Adult Bedrooms', fr: 'Chambres Adultes', nl: 'Volwassen Slaapkamers' },
  'youth-bedrooms': { en: 'Youth Bedrooms', fr: 'Chambres Jeunes', nl: 'Jeugd Slaapkamers' },
  'baby-bedrooms': { en: 'Baby Bedrooms', fr: 'Chambres Bébé', nl: 'Baby Slaapkamers' },
  'office': { en: 'Offices', fr: 'Bureaux', nl: 'Kantoren' },
  'dining': { en: 'Dining Rooms', fr: 'Salles à Manger', nl: 'Eetkamers' }
};

function getCategoryName(category: string, locale: 'en' | 'fr' | 'nl'): string {
  return categoryLabels[category]?.[locale] || category;
}
---

<BaseLayout title="Neyt Furniture - Fine furniture for fine people" locale={locale}>
  <Header locale={locale} />
  
  <main>
    <!-- Hero Section -->
    <section class="relative h-[600px] bg-gradient-to-br from-primary to-secondary overflow-hidden">
      <div class="absolute inset-0 bg-black/20"></div>
      <div class="relative container h-full flex flex-col justify-center items-center text-center text-white">
        <h1 class="text-5xl md:text-7xl font-serif font-bold mb-6 animate-fade-in">
          {companyData.company.names[locale]}
        </h1>
        <p class="text-xl md:text-3xl mb-8 max-w-3xl font-light">
          {companyData.company.taglines[locale]}
        </p>
        <div class="flex gap-4">
          <a href="/furniture" class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-gray-100 transition-all transform hover:scale-105 shadow-lg">
            {locale === 'nl' ? 'Bekijk Collectie' : locale === 'fr' ? 'Voir Collection' : 'View Collection'}
          </a>
          <a href="/about" class="inline-block bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-primary transition-all">
            {locale === 'nl' ? 'Over Ons' : locale === 'fr' ? 'À Propos' : 'About Us'}
          </a>
        </div>
      </div>
    </section>

    <!-- Recent Additions -->
    <section class="section bg-gray-50">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-serif font-bold mb-4">
            {locale === 'nl' ? 'Nieuwste Toevoegingen' : locale === 'fr' ? 'Derniers Ajouts' : 'Recent Additions'}
          </h2>
          <p class="text-gray-600 text-lg">
            {locale === 'nl' ? 'Ontdek onze nieuwste meubelen' : locale === 'fr' ? 'Découvrez nos derniers meubles' : 'Discover our latest furniture pieces'}
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {recentFurniture.map(item => {
            const images = item.images || [item.image_url];
            const itemName = locale === 'nl' ? item.name_nl : (locale === 'fr' ? item.name_fr : item.name_en) || item.name_nl;
            
            return (
              <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all transform hover:-translate-y-1">
                <div class="aspect-[4/3] bg-gray-200 overflow-hidden">
                  <img 
                    src={images[0]} 
                    alt={itemName} 
                    class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" 
                    loading="lazy" 
                  />
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-semibold mb-2">{itemName}</h3>
                  <p class="text-gray-600 text-sm mb-3">
                    {getCategoryName(item.categories?.[0] || item.category, locale)}
                  </p>
                  {item.pdf_url && (
                    <a 
                      href={item.pdf_url} 
                      target="_blank"
                      class="inline-flex items-center gap-2 text-accent hover:text-accent/80 text-sm font-medium"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      {locale === 'nl' ? 'Download PDF' : locale === 'fr' ? 'Télécharger PDF' : 'Download PDF'}
                    </a>
                  )}
                </div>
              </article>
            );
          })}
        </div>

        <div class="text-center mt-12">
          <a 
            href="/furniture" 
            class="inline-block bg-accent text-white px-8 py-3 rounded-lg font-semibold hover:bg-accent/90 transition-colors"
          >
            {locale === 'nl' ? 'Bekijk Alle Meubelen' : locale === 'fr' ? 'Voir Tous Les Meubles' : 'View All Furniture'}
          </a>
        </div>
      </div>
    </section>

    <!-- Closing Dates -->
    {companyData.closingDates.length > 0 && (
      <section class="section">
        <div class="container max-w-3xl">
          <div class="bg-white rounded-lg shadow-lg p-8 border-l-4 border-accent">
            <h3 class="text-2xl font-serif font-bold mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {locale === 'nl' ? 'Sluitingsdagen' : locale === 'fr' ? 'Dates de Fermeture' : 'Closing Dates'} {companyData.closingDates[0].year}
            </h3>
            <ul class="space-y-3">
              {companyData.closingDates[0].periods.map(period => (
                <li class="flex items-start gap-3">
                  <span class="text-accent text-xl mt-0.5">•</span>
                  <span class="text-gray-700">{period}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class="section bg-gradient-to-br from-primary to-secondary text-white">
      <div class="container text-center">
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">
          {locale === 'nl' ? 'Klaar om uw perfecte meubel te vinden?' : locale === 'fr' ? 'Prêt à trouver votre meuble parfait?' : 'Ready to find your perfect furniture?'}
        </h2>
        <p class="text-xl mb-8 max-w-2xl mx-auto opacity-90">
          {locale === 'nl' ? 'Bezoek onze showroom of neem contact met ons op voor persoonlijk advies' : locale === 'fr' ? 'Visitez notre showroom ou contactez-nous pour des conseils personnalisés' : 'Visit our showroom or contact us for personalized advice'}
        </p>
        <a href="/contact" class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-gray-100 transition-all transform hover:scale-105 shadow-lg">
          {locale === 'nl' ? 'Contact Opnemen' : locale === 'fr' ? 'Nous Contacter' : 'Get in Touch'}
        </a>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>