---
// filepath: c:\Users\h039864\OneDrive - Baloise\personal\neyt-main\src\layouts\BaseLayout.astro
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  locale?: 'en' | 'fr' | 'nl';
  canonical?: string;
  ogImage?: string;
}

const { 
  title, 
  description = 'Quality furniture for your home', 
  locale = 'en',
  canonical,
  ogImage = '/images/furniture/prodlogo.png'
} = Astro.props;

const canonicalURL = canonical || Astro.url.href;
const siteURL = 'https://www.neytfurniture.com';
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${siteURL}${ogImage}`} />
    <meta property="og:site_name" content="Neyt Furniture" />
    <meta property="og:locale" content={locale === 'nl' ? 'nl_BE' : locale === 'fr' ? 'fr_BE' : 'en_GB'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}${ogImage}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-gray-50">
    <slot />
  </body>
</html>